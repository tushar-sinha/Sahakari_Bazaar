generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Investor {
  id         String   @id @default(cuid())
  name       String
  mobile     String   @unique
  email      String?
  address    String
  city       String
  state      String
  pincode    String
  profession String
  investment Float?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StorePartner {
  id           String    @id @default(cuid())
  storeName    String
  ownerName    String
  mobile       String    @unique
  email        String?
  address      String
  city         String
  state        String
  pincode      String
  latitude     Float?
  longitude    Float?
  category     String    @default("grocery")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bio          String?
  website      String?
  profileImage String?
  orders       Order[]
  products     Product[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  mobile    String   @unique
  email     String?  @unique
  password  String?
  address   String?
  city      String?
  state     String?
  pincode   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  image    String
  products Product[]
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  price       Float
  mrp         Float
  unit        String        @default("1 kg")
  image       String
  inStock     Boolean       @default(true)
  categoryId  String
  storeId     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  orderItems  OrderItem[]
  store       StorePartner? @relation(fields: [storeId], references: [id])
  category    Category      @relation(fields: [categoryId], references: [id])
}

model Order {
  id          String        @id @default(cuid())
  orderNumber String        @unique
  customerId  String?
  storeId     String?
  status      String        @default("pending")
  subtotal    Float
  deliveryFee Float         @default(0)
  total       Float
  address     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  store       StorePartner? @relation(fields: [storeId], references: [id])
  customer    Customer?     @relation(fields: [customerId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id])
}

model MobilityUser {
  id                 String              @id @default(cuid())
  phoneNumber        String              @unique
  name               String
  email              String?             @unique
  profileImage       String?
  role               String              @default("rider")
  rating             Float               @default(5.0)
  totalRides         Int                 @default(0)
  documentUrl        String?
  isVerified         Boolean             @default(false)
  isActive           Boolean             @default(true)
  bankAccount        String?
  emergencyContact   String?
  latitude           Float?
  longitude          Float?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  liveLocations      LiveLocation[]
  ridesAsDriver      Ride[]              @relation("Driver")
  ridesAsRider       Ride[]              @relation("Rider")
  reviews            RideReview[]
  vehicles           Vehicle[]
  walletTransactions WalletTransaction[]
}

model Vehicle {
  id                 String       @id @default(cuid())
  driverId           String
  type               String       @default("cab")
  registrationNumber String       @unique
  make               String
  model              String
  year               Int
  color              String
  capacity           Int          @default(4)
  licenseUrl         String?
  insuranceUrl       String?
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  rides              Ride[]
  driver             MobilityUser @relation(fields: [driverId], references: [id])
}

model Ride {
  id                String         @id @default(cuid())
  rideNumber        String         @unique
  riderId           String
  driverId          String?
  vehicleId         String?
  serviceType       String
  loadType          String?
  helperNeeded      Boolean        @default(false)
  pickupLat         Float
  pickupLon         Float
  pickupAddress     String
  dropoffLat        Float
  dropoffLon        Float
  dropoffAddress    String
  estimatedDistance Float?
  estimatedDuration Int?
  baseFare          Float
  distanceRate      Float
  estimatedFare     Float
  actualFare        Float?
  discount          Float?         @default(0)
  tax               Float?         @default(0)
  totalFare         Float?
  status            String         @default("requested")
  paymentStatus     String         @default("pending")
  paymentMethod     String         @default("cash")
  specialNotes      String?
  riderNotes        String?
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  locations         LiveLocation[]
  vehicle           Vehicle?       @relation(fields: [vehicleId], references: [id])
  driver            MobilityUser?  @relation("Driver", fields: [driverId], references: [id])
  rider             MobilityUser   @relation("Rider", fields: [riderId], references: [id])
  review            RideReview?
}

model LiveLocation {
  id        String       @id @default(cuid())
  rideId    String
  userId    String
  latitude  Float
  longitude Float
  accuracy  Float?
  heading   Float?
  speed     Float?
  timestamp DateTime     @default(now())
  user      MobilityUser @relation(fields: [userId], references: [id])
  ride      Ride         @relation(fields: [rideId], references: [id])

  @@index([rideId])
  @@index([userId])
  @@index([timestamp])
}

model RideReview {
  id         String       @id @default(cuid())
  rideId     String       @unique
  reviewerId String
  rating     Int
  comment    String?
  categories String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  reviewer   MobilityUser @relation(fields: [reviewerId], references: [id])
  ride       Ride         @relation(fields: [rideId], references: [id])
}

model DriverStatus {
  id            String   @id @default(cuid())
  driverId      String   @unique
  isOnline      Boolean  @default(false)
  isAvailable   Boolean  @default(false)
  currentRideId String?
  latitude      Float?
  longitude     Float?
  lastUpdated   DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WalletTransaction {
  id            String       @id @default(cuid())
  userId        String
  amount        Float
  type          String
  reason        String
  rideId        String?
  balanceBefore Float?
  balanceAfter  Float?
  status        String       @default("completed")
  createdAt     DateTime     @default(now())
  user          MobilityUser @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}
