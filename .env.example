# ─── NextAuth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Your Railway public domain (set after first deploy)
NEXTAUTH_URL=https://sahakari-bazaar.up.railway.app

# ─── Database ────────────────────────────────────────────────────────────────
# Path to SQLite file.
# On Railway, mount a Volume at /data and set this to:
DATABASE_URL=file:/data/sahakari.db
# Locally, leave this unset — it defaults to ./prisma/sahakari.db
